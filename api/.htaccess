# Transmet l'en-tête Authorization à PHP (sinon Bearer token perdu sur Apache/CGI)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} ^(.+)$
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
</IfModule>

# Variante CGI/FastCGI
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Empêche l'accès direct aux fichiers sensibles
<FilesMatch "^(config\.php|config\.sample\.php|schema\.sql|bootstrap\.php)$">
  Require all denied
</FilesMatch>
